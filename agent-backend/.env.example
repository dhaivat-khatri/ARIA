# Agent Backend Environment Variables — Ollama (local) edition
# Copy this file to .env — no API keys needed!

# Ollama server URL
OLLAMA_BASE_URL=http://localhost:11434

# Local model to use (must be pulled first: ollama pull llama3.1)
# Recommended: llama3.1, mistral, qwen2.5, llama3.2
OLLAMA_MODEL=llama3.1

# LLM temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.2

# URL of the MCP server
MCP_SERVER_URL=http://localhost:8001
